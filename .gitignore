.DS_Store

# generated media — NOT versioned (regenerable; deliverables live on YouTube;
# source of truth is the scene text + the studio engine)
*.png
*.jpg
*.jpeg
*.webp
*.mp3
*.mp4
*.m4a
*.wav
*.glb
*.pdf

# ffmpeg 2-pass stats (junk)
*.mbtree
ffmpeg2pass*.log*

# table-read production output — entirely regenerable from the tracked
# performance_sceneXX.json scripts + the source .fountain files
stories/*/tableread/segs*/
stories/*/tableread/refsheets/
stories/*/tableread/index.html
