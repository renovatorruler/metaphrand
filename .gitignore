# nearly lost work; source of truth is the scene text + the studio engine)
*.png
*.jpg
*.jpeg
*.webp
*.mp3
*.mp4
*.m4a
*.wav
*.glb
*.pdf

# git worktrees live here; never tracked by the parent repo
.claude/worktrees/
*.audio
